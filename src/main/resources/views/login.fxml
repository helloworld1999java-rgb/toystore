<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.toy.controller.LoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #1a252f, #2c3e50);">
    <center>
        <VBox alignment="CENTER" spacing="16"
              style="-fx-background-color:white; -fx-background-radius:16;
                     -fx-padding:40 50 40 50;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.30),20,0,0,8);"
              maxWidth="380">
            <Label text="🧸" style="-fx-font-size:52px;"/>
            <Label text="ToyStore"
                   style="-fx-font-size:26px; -fx-font-weight:bold; -fx-text-fill:#2c3e50;"/>
            <Label text="Войдите в аккаунт"
                   style="-fx-font-size:13px; -fx-text-fill:#95a5a6;"/>
            <VBox spacing="6" style="-fx-padding:10 0 0 0;">
                <Label text="Email" style="-fx-text-fill:#555;"/>
                <TextField fx:id="emailField" promptText="you@example.com"
                           prefWidth="280"
                           style="-fx-background-radius:8; -fx-border-radius:8;
                                  -fx-border-color:#dde1e7; -fx-padding:8 12 8 12;"/>
            </VBox>
            <VBox spacing="6">
                <Label text="Пароль" style="-fx-text-fill:#555;"/>
                <PasswordField fx:id="passField" promptText="••••••••"
                               prefWidth="280"
                               style="-fx-background-radius:8; -fx-border-radius:8;
                                      -fx-border-color:#dde1e7; -fx-padding:8 12 8 12;"/>
            </VBox>
            <Button text="Войти →" onAction="#handleLogin"
                    prefWidth="280" prefHeight="40"
                    style="-fx-background-color:#2980b9; -fx-text-fill:white;
                           -fx-background-radius:8; -fx-font-size:14px;
                           -fx-font-weight:bold; -fx-cursor:hand;"/>
            <Separator/>
            <HBox alignment="CENTER" spacing="5">
                <Label text="Нет аккаунта?" style="-fx-text-fill:#95a5a6;"/>
                <Hyperlink text="Зарегистрироваться" onAction="#goToRegister"
                           style="-fx-text-fill:#3498db;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
