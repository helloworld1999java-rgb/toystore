<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.toy.controller.AdminToysController">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color:#1a252f; -fx-padding:12 20 12 20;">
            <Label text="📦 Управление товарами"
                   style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Назад" onAction="#goBack"
                    style="-fx-background-color:#95a5a6; -fx-text-fill:white;
                           -fx-background-radius:8; -fx-cursor:hand;"/>
        </HBox>
    </top>
    <center>
        <SplitPane>
            <TableView fx:id="toysTable" style="-fx-background-color:white;">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"        prefWidth="50"/>
                    <TableColumn fx:id="colName"     text="Название"  prefWidth="200"/>
                    <TableColumn fx:id="colPrice"    text="Цена"      prefWidth="80"/>
                    <TableColumn fx:id="colStock"    text="Остаток"   prefWidth="80"/>
                    <TableColumn fx:id="colMinStock" text="Мин.запас" prefWidth="90"/>
                </columns>
            </TableView>
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color:#f0f2f5;">
                <VBox spacing="10"
                      style="-fx-padding:15; -fx-background-color:#f0f2f5;">
                    <Label text="Карточка товара"
                           style="-fx-font-weight:bold; -fx-font-size:14px; -fx-text-fill:#2c3e50;"/>
                    <TextField fx:id="nameField"     promptText="Название"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <ComboBox  fx:id="categoryCombo" maxWidth="Infinity"
                               style="-fx-background-radius:8;"/>
                    <TextField fx:id="priceField"    promptText="Цена (₽)"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <TextField fx:id="stockField"    promptText="Количество на складе"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <TextField fx:id="minStockField" promptText="Минимальный запас"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <TextField fx:id="ageField"      promptText="Возраст от (лет)"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <TextField fx:id="colorField"    promptText="Цвет"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <TextField fx:id="materialField" promptText="Материал"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <TextField fx:id="sizeField"     promptText="Размер"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <TextArea  fx:id="descField"     promptText="Описание"
                               prefHeight="80" wrapText="true"
                               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8;"/>
                    <HBox spacing="10">
                        <Button text="➕ Добавить" onAction="#handleAdd"
                                style="-fx-background-color:#27ae60; -fx-text-fill:white;
                                       -fx-background-radius:8; -fx-cursor:hand; -fx-font-weight:bold;"/>
                        <Button text="✏️ Обновить" onAction="#handleUpdate"
                                style="-fx-background-color:#3498db; -fx-text-fill:white;
                                       -fx-background-radius:8; -fx-cursor:hand; -fx-font-weight:bold;"/>
                        <Button text="🗑 Удалить" onAction="#handleDelete"
                                style="-fx-background-color:#e74c3c; -fx-text-fill:white;
                                       -fx-background-radius:8; -fx-cursor:hand; -fx-font-weight:bold;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
