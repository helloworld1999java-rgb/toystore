<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      style="-fx-padding:30; -fx-background-color:#f0f2f5;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.toy.controller.ProfileController">
    <Label text="👤 Ваш профиль"
           style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#2c3e50;"/>
    <TextField fx:id="nameField" promptText="ФИО"
               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8 12 8 12;"/>
    <TextField fx:id="phoneField" promptText="Телефон"
               style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8 12 8 12;"/>
    <TextArea fx:id="addressField" promptText="Адрес доставки"
              prefHeight="100" wrapText="true"
              style="-fx-background-radius:8; -fx-border-color:#dde1e7; -fx-padding:8 12 8 12;"/>
    <HBox spacing="10">
        <Button text="💾 Сохранить" onAction="#saveChanges"
                style="-fx-background-color:#27ae60; -fx-text-fill:white;
                       -fx-background-radius:8; -fx-cursor:hand; -fx-font-weight:bold;
                       -fx-padding:10 20 10 20;"/>
        <Button text="⏻ Выйти" onAction="#handleLogout"
                style="-fx-background-color:#e74c3c; -fx-text-fill:white;
                       -fx-background-radius:8; -fx-cursor:hand; -fx-font-weight:bold;
                       -fx-padding:10 20 10 20;"/>
    </HBox>
    <Button text="← Назад к покупкам" onAction="#goBack"
            style="-fx-background-color:#95a5a6; -fx-text-fill:white;
                   -fx-background-radius:8; -fx-cursor:hand;"/>
</VBox>
