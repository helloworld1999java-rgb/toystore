<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      style="-fx-padding:20; -fx-background-color:#f0f2f5;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.toy.controller.ReceiptController">
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="🧾 Мои чеки"
               style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#2c3e50;"/>
        <Button text="← Назад" onAction="#goBack"
                style="-fx-background-color:#95a5a6; -fx-text-fill:white;
                       -fx-background-radius:8; -fx-cursor:hand;"/>
    </HBox>
    <ListView fx:id="receiptsList" VBox.vgrow="ALWAYS" prefHeight="500"
              style="-fx-background-radius:10; -fx-border-color:#e8ecef; -fx-background-color:white;"/>
</VBox>
