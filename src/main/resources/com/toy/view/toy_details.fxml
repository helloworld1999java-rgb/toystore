<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" alignment="CENTER" style="-fx-padding: 25;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.toy.controller.ToyDetailsController">
    <Label fx:id="nameLabel" style="-fx-font-size: 22; -fx-font-weight: bold;" />
    <Label fx:id="categoryLabel" style="-fx-text-fill: gray;" />
    <TextArea fx:id="descArea" editable="false" wrapText="true" prefHeight="150" />
    <HBox spacing="15" alignment="CENTER">
        <Label fx:id="priceLabel" style="-fx-font-size: 18; -fx-text-fill: green;" />
        <Button text="Добавить в корзину" onAction="#addToCart" />
    </HBox>
</VBox>